# Copy to .env and fill in values.

# Telegram
TELEGRAM_BOT_TOKEN=
PROTECTED_CHAT_ID=
ADMIN_USER_IDS=
SUPPORT_USER_IDS=

# Plans (comma-separated; seeded on first run if DB is empty)
DEFAULT_PLAN_ID=monthly
AVAILABLE_PLAN_IDS=monthly
PLAN_monthly_NAME=Monthly
PLAN_monthly_PRICE_CENTS=999
PLAN_monthly_DURATION_DAYS=30
PLAN_monthly_STARS_PRICE=100

# Display
DISPLAY_CURRENCY=USD

# Local DB
DB_PATH=./data/bot.sqlite3

# HTTP server (FastAPI webhooks for Stripe / CryptoBot)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# Testing: mock provider completes after ~10s without real payment
MOCK_PAYMENTS=true

# Telegram Stars (XTR)
STARS_ENABLED=true

# CryptoBot (@CryptoBot / pay.crypt.bot)
CRYPTOBOT_ENABLED=false
CRYPTOBOT_TOKEN=

# Stripe
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_WEBHOOK_SECRET=

# PayPal (optional)
PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_RETURN_URL=
PAYPAL_CANCEL_URL=
PAYPAL_WEBHOOK_ID=
