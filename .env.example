# Copy to .env and fill in values.

# Telegram
TELEGRAM_BOT_TOKEN=1111111111:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
PROTECTED_CHAT_ID=-1111111111
ADMIN_USER_IDS=1111111111
SUPPORT_USER_IDS=1111111111

# Plans (comma-separated; seeded on first run if DB is empty)
DEFAULT_PLAN_ID=monthly
AVAILABLE_PLAN_IDS=monthly
PLAN_monthly_NAME=Monthly
PLAN_monthly_PRICE_CENTS=999
PLAN_monthly_DURATION_DAYS=30
PLAN_monthly_STARS_PRICE=100

# Display
DISPLAY_CURRENCY=USD

# Local DB
DB_PATH=./data/bot.sqlite3

# HTTP server (FastAPI webhooks for Stripe / CryptoBot)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# Testing: mock provider completes after ~10s without real payment
MOCK_PAYMENTS=true

# Telegram Stars (XTR)
STARS_ENABLED=true

# CryptoBot (@CryptoBot / pay.crypt.bot)
CRYPTOBOT_ENABLED=false
CRYPTOBOT_TOKEN=1111111111:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Stripe
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=1111111111:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
STRIPE_SUCCESS_URL=https://example.com/stripe/success
STRIPE_CANCEL_URL=https://example.com/stripe/cancel
STRIPE_WEBHOOK_SECRET=1111111111:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# PayPal (optional)
PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=1111111111:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
PAYPAL_CLIENT_SECRET=1111111111:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
PAYPAL_ENV=sandbox
PAYPAL_RETURN_URL=https://example.com/paypal/success
PAYPAL_CANCEL_URL=https://example.com/paypal/cancel
PAYPAL_WEBHOOK_ID=1111111111:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
