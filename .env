TELEGRAM_BOT_TOKEN=1111111111:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Comma-separated list of Telegram user IDs that can administer the bot
ADMIN_USER_IDS=1111111111

# Target private channel/group to protect.
# - If it's a channel: use the numeric chat id (recommended)
# - If it's a group: numeric chat id
PROTECTED_CHAT_ID=-1111111111

# Access is granted via invite link that expires after some time.
INVITE_LINK_EXPIRE_SECONDS=3600

# SQLite database path
DB_PATH=./data/bot.sqlite3

# Currency shown to users for pricing display
DISPLAY_CURRENCY=EUR

# Plans (seeded on first run; used by /buy and /grant)
AVAILABLE_PLAN_IDS=quarterly
DEFAULT_PLAN_ID=quarterly
PLAN_quarterly_NAME=3 месяца — 39,99 €
PLAN_quarterly_PRICE_CENTS=3999
PLAN_quarterly_DURATION_DAYS=90
PLAN_quarterly_STARS_PRICE=2600

# Stripe
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=https://example.com/success
STRIPE_CANCEL_URL=https://example.com/cancel

# PayPal (v2 Orders API)
PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox  # sandbox|live
PAYPAL_RETURN_URL=https://example.com/paypal/return
PAYPAL_CANCEL_URL=https://example.com/paypal/cancel

# Coinbase Commerce (crypto / stablecoins supported by Coinbase Commerce)
COINBASE_ENABLED=false
COINBASE_API_KEY=
COINBASE_WEBHOOK_SHARED_SECRET=

# Set true to avoid calling external payment APIs (returns fake checkout URLs)
MOCK_PAYMENTS=true
